{
  "name": "xgov-opensource-repo-scraper",
  "version": "2.0.0",
  "description": "Scrapes UK Government open source repositories from GitHub",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "get-all": "node index.js get-all -w ./public/repos.json",
    "get-orgs": "node index.js get-orgs",
    "lint": "eslint .",
    "test": "npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UKHomeOffice/xgov-opensource-repo-scraper.git"
  },
  "author": "Chris Nesbitt-Smith",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/UKHomeOffice/xgov-opensource-repo-scraper/issues"
  },
  "homepage": "https://github.com/UKHomeOffice/xgov-opensource-repo-scraper#readme",
  "dependencies": {
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^21.1.1",
    "commander": "^13.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0"
  }
}
